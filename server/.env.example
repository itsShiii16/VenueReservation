# ──────────────────────────────────────────────
# UPD Venue Reservation System — Environment
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vrs_db?schema=public"

# JWT secret key — use a long random string in production
JWT_SECRET="change-me-to-a-random-secret-key"

# JWT token expiry (e.g., "7d", "24h", "1h")
JWT_EXPIRES_IN="7d"

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:5173"
